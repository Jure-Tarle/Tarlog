{
  "expo": {
    "name": "Tarlog",
    "slug": "ptl-mobile",
    "scheme": "ptl",
    "version": "0.0.6",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.tarlog.mobile",
      "supportsTablet": true,
      "buildNumber": "3"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
