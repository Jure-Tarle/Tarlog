{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Time Ledger",
  "version": "0.0.1",
  "identifier": "com.ptl.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Project Time Ledger",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Project Time Ledger"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Revisionsfähige lokale Zeiterfassung",
    "longDescription": "Project Time Ledger — professionelle, revisionsfähige und datenschutzfreundliche Zeiterfassung. Lokaler Desktop-Modus mit optionalem Server-Sync.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {},
      "nsis": {}
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:ptl.db"]
    },
    "notification": {}
  }
}
