# Tarlog — Web (Server-Modus). Kopie nach `.env` / `.env.local`.
# Zeiten sind epoch-ms UTC; Geld Integer-Cents; keine Secrets in Logs (doc 09).

# PostgreSQL-Verbindung (Pflicht im Server-Modus, doc 05 §9.2).
DATABASE_URL=postgres://ptl:ptl@localhost:5432/ptl

# Signierung sicherer Sessions (langer Zufallswert, doc 05 §9.2, doc 09).
SESSION_SECRET=change-me-to-a-long-random-secret

# HTTP-Port des Custom-Node-Servers (server.mjs).
PORT=3000

# Basis-URL für Links/Redirects (öffentlich sichtbar).
NEXT_PUBLIC_APP_URL=http://localhost:3000
