# Project Time Ledger — Docker-Compose-Umgebung (Server-Modus).
# Kopie nach `.env` (liegt neben docker-compose.yml). doc 05 §9.2.
# Zeiten sind epoch-ms UTC; Geld Integer-Cents; keine Secrets in Logs (doc 09).
#
#   cp .env.example .env   &&   docker compose up -d --build

# --- PostgreSQL (Dienst `postgres`) ----------------------------------------
POSTGRES_USER=ptl
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=ptl

# --- Web-Dienst -------------------------------------------------------------
# Optional explizit; sonst aus POSTGRES_* zusammengesetzt (Host = `postgres`).
# DATABASE_URL=postgres://ptl:change-me-postgres-password@postgres:5432/ptl

# Pflicht: langer Zufallswert für sichere Sessions (doc 05 §9.2, doc 09).
# Erzeugen z. B.: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-secret

# HTTP-Port (Host == Container). server.mjs lauscht auf PORT.
PORT=3000

# Öffentliche Basis-URL für Links/Redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Im Health-Endpoint (/api/health) ausgewiesene Version.
NEXT_PUBLIC_APP_VERSION=0.0.0

# --- Optional: Redis (Hintergrundjobs) -------------------------------------
# redis-Dienst in docker-compose.yml einkommentieren, dann:
# REDIS_URL=redis://redis:6379
